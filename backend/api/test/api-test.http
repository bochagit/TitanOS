### Variables
@baseUrl = http://localhost:8080
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiI5NTUzMWM0ZS1hYTE2LTQzMDktOTEzZi0wNzc0ZmZjOTU2YjkiLCJneW1JZCI6ImEwMTY0NWRkLTMzZjUtNDBjNC1iMjlhLTFkMDg2YzI5ZTc3OSIsInJvbGUiOiJPV05FUiIsImlhdCI6MTc3MzE5NjY0MywiZXhwIjoxNzczODAxNDQzfQ.H69iYYvdP_WqWU5KlYtsKp1FOCOO4PbuLdqZUtAg4X0
@gymId = a01645dd-33f5-40c4-b29a-1d086c29e779
@studentId = 74056161-eb9f-433e-bc76-527725483c77

### ==========================================
### 1. CREAR GYM (Público)
### ==========================================
POST {{baseUrl}}/gyms
Content-Type: application/json

{
  "name": "Titan Gym",
  "logoUrl": "https://example.com/logo.png",
  "primaryColor": "#0000FF",
  "secondaryColor": "#FFFFFF"
}

### COPIA EL "id" Y PEGALO EN @gymId ARRIBA


### ==========================================
### 2. REGISTRAR USUARIO
### ==========================================
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "admin@titangym.com",
  "password": "password123",
  "name": "Admin User",
  "role": "OWNER",
  "gymId": "{{gymId}}"
}

### COPIA EL "access_token" Y PEGALO EN @token ARRIBA


### ==========================================
### 3. LOGIN
### ==========================================
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@titangym.com",
  "password": "password123"
}


### ==========================================
### 4. LISTAR GYMS (Protegido)
### ==========================================
GET {{baseUrl}}/gyms
Authorization: Bearer {{token}}


### ==========================================
### 5. OBTENER UN GYM (Protegido)
### ==========================================
GET {{baseUrl}}/gyms/{{gymId}}
Authorization: Bearer {{token}}


### ==========================================
### 6. ACTUALIZAR GYM (Protegido)
### ==========================================
PATCH {{baseUrl}}/gyms/{{gymId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Titan Gym Actualizado",
  "primaryColor": "#0000FF"
}


### ==========================================
### 7. CREAR ESTUDIANTE (Protegido)
### ==========================================
POST {{baseUrl}}/students
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Juan Pérez",
  "email": "juan@example.com",
  "phone": "+1234567890",
  "gymId": "{{gymId}}"
}

### COPIA EL "id" Y PEGALO EN @studentId ARRIBA


### ==========================================
### 8. LISTAR ESTUDIANTES (Protegido)
### ==========================================
GET {{baseUrl}}/students
Authorization: Bearer {{token}}


### ==========================================
### 9. OBTENER UN ESTUDIANTE (Protegido)
### ==========================================
GET {{baseUrl}}/students/{{studentId}}
Authorization: Bearer {{token}}


### ==========================================
### 10. ACTUALIZAR ESTUDIANTE (Protegido)
### ==========================================
PATCH {{baseUrl}}/students/{{studentId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "phone": "+0987654321",
  "email": "juan.perez@example.com"
}


### ==========================================
### 11. ELIMINAR ESTUDIANTE (Protegido)
### ==========================================
DELETE {{baseUrl}}/students/{{studentId}}
Authorization: Bearer {{token}}


### ==========================================
### 12. ELIMINAR GYM (Protegido)
### ==========================================
DELETE {{baseUrl}}/gyms/{{gymId}}
Authorization: Bearer {{token}}


### ==========================================
### PRUEBAS DE SEGURIDAD
### ==========================================

### Sin token (debe dar 401)
GET {{baseUrl}}/students

### Token inválido (debe dar 401)
GET {{baseUrl}}/students
Authorization: Bearer token_invalido
